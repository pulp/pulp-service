# Build stage
FROM registry.access.redhat.com/ubi9/go-toolset:9.7 AS builder

WORKDIR /opt/app-root/src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -buildvcs=false -o agent-splunk .

# Runtime stage
FROM registry.access.redhat.com/ubi9-minimal:latest

WORKDIR /app

COPY --from=builder /opt/app-root/src/agent-splunk .

USER 1001

ENTRYPOINT ["./agent-splunk"]

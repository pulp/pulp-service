diff --git a/pulpcore/download/base.py b/pulpcore/download/base.py
index b093ad9e4..ab8acff4b 100644
--- a/pulpcore/download/base.py
+++ b/pulpcore/download/base.py
@@ -1,6 +1,7 @@
 from gettext import gettext as _
 

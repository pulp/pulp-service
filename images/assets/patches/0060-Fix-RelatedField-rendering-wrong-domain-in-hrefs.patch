From 934c752dae916857b2005e1fe0ef75496accc082 Mon Sep 17 00:00:00 2001
From: Jitka Halova <jobselko@redhat.com>
Date: Thu, 2 Jul 2026 13:29:30 +0200
Subject: [PATCH] Fix RelatedField rendering wrong domain in hrefs

closes #7835
Assisted By: Claude Opus 4.6
---
 pulpcore/app/serializers/base.py | 10 ++++++++++
 1 file changed, 10 insertions(+)

diff --git a/pulpcore/app/serializers/base.py b/pulpcore/app/serializers/base.py
index 8eac0ebfc..9d5538a4a 100644
--- a/pulpcore/app/serializers/base.py
+++ b/pulpcore/app/serializers/base.py
@@ -67,6 +67,16 @@ def _reverse(obj):
 class HrefPrnFieldMixin:
     """A mixin to configure related fields to generate relative hrefs and accept PRNs."""
 
+    def use_pk_only_optimization(self):
+        """Disable DRF's PK-only optimization when domains are enabled.
+
+        DRF's optimization passes a PKOnlyObject (no pulp_domain) to get_url,
+        causing _reverse to fall back to the default domain.
+        """
+        if settings.DOMAIN_ENABLED:
+            return False
+        return super().use_pk_only_optimization()
+
     def get_url(self, obj, view_name, request, *args, **kwargs):
         # Use the Pulp reverse method to display relative hrefs.
         self.reverse = _reverse(obj)
-- 
2.54.0


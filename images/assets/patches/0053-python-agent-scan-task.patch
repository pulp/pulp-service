@@ -0,0 +1,43 @@
+import logging
+import os
+import shutil
+import subprocess
+import tempfile
+
+from pulpcore.plugin.models import ContentArtifact, RepositoryVersion
+
+log = logging.getLogger(__name__)
+
+def scan_package(repo_version_pk: str):
+    repo_version = RepositoryVersion.objects.get(pk=repo_version_pk)
+    content_artifacts = ContentArtifact.objects.filter(content__pulp_type="python.python", content__in=repo_version.content, artifact__isnull=False).select_related("artifact")
+    with tempfile.TemporaryDirectory(dir=".") as working_directory:
+        working_directory = os.path.abspath(working_directory)
+        files = set()
+        for ca in content_artifacts:
+            dest_path = os.path.join(working_directory, ca.relative_path)
+            files.add(dest_path)
+            with ca.artifact.file.open("rb") as src, open(dest_path, "wb") as dest:
+                shutil.copyfileobj(src, dest)
+
+        files = ",".join(map(str, files))
+        _run_scan_agent(files)
+
+def _run_scan_agent(artifacts):
+    process = subprocess.Popen(
+        [
+        "agent-scan",
+        "--files",
+        artifacts
+        ],
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True
+    )
+    for line in process.stdout:
+        log.info(line.rstrip())
+    for line in process.stderr:
+        log.error(line.rstrip())
+    process.wait()
+    if process.returncode != 0:
+        raise Exception(f"agent-scan failed with return code {process.returncode}")

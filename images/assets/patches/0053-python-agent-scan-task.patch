--- /dev/null
+++ b/pulp_python/app/tasks/scan_package.py
+import logging
+import os
+import shutil
+import subprocess
+import tempfile
+
+from pulpcore.plugin.models import Content, ContentArtifact, CreatedResource, RepositoryVersion
+from pulp_service.app.models import AgentScanReport
+
+log = logging.getLogger(__name__)
+
+
+def scan_package(repo_version_pk: str, content_pk: str):
+    repo_version = RepositoryVersion.objects.get(pk=repo_version_pk)
+    content = Content.objects.get(pk=content_pk)
+    content_artifacts = (
+        ContentArtifact.objects.filter(
+            content=content,
+            content__pulp_type="python.python",
+            artifact__isnull=False,
+        )
+        .exclude(relative_path__endswith=".metadata")
+        .select_related("artifact", "content")
+    )
+    with tempfile.TemporaryDirectory(dir=".") as working_directory:
+        working_directory = os.path.abspath(working_directory)
+        for ca in content_artifacts:
+            dest_path = os.path.join(working_directory, ca.relative_path)
+            with ca.artifact.file.open("rb") as src, open(dest_path, "wb") as dest:
+                shutil.copyfileobj(src, dest)
+
+            response = _run_scan_agent(dest_path)
+            report, created = AgentScanReport.objects.update_or_create(
+                content=ca.content,
+                defaults={"reports": response},
+            )
+            report.repo_versions.add(repo_version)
+            if created:
+                CreatedResource.objects.create(content_object=report)
+
+
+def _run_scan_agent(artifact):
+    process = subprocess.Popen(
+        ["agent-scan", "--files", artifact],
+        stdout=subprocess.PIPE,
+        stderr=subprocess.PIPE,
+        text=True,
+    )
+    response_lines = ""
+    for line in process.stdout:
+        log.info(line.rstrip())
+        response_lines += line
+    for line in process.stderr:
+        log.error(line.rstrip())
+    process.wait()
+    if process.returncode != 0:
+        raise Exception(f"agent-scan failed with return code {process.returncode}")
+    return response_lines
